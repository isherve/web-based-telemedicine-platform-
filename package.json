{
  "name": "gara",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Gara - offline-capable telemedicine platform for solo private clinics (React + local Node/SQLite backend)",
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "npm --prefix server run dev",
    "build": "vite build",
    "start": "npm --prefix server start",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "npm install && npm --prefix server install"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
