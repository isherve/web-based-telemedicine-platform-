# ---- Frontend (Vite) ----
# Local dev: leave empty — Vite proxies /api to localhost:4000.
# Vercel: set to your Render API URL, e.g. https://gara-api.onrender.com
VITE_API_URL=

# ---- Backend (see server/.env.example for the server copy) ----
# The following are consumed by the local Node/Express server, not the frontend.
# They are listed here for reference; put real values in server/.env

# Port the local backend listens on
PORT=4000

# One-time token required to register a doctor account (doctor gate)
DOCTOR_REGISTRATION_TOKEN=gara-doctor-2026

# --- Optional online integrations (app works fully offline without these) ---
# If set, the AI brief will call Groq instead of using the offline template.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# If set, OTP reset emails are sent via Gmail SMTP instead of shown on screen.
GMAIL_SMTP_USER=
GMAIL_SMTP_PASS=
