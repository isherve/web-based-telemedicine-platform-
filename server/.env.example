# Local backend configuration (offline-capable)
PORT=4000

# CORS origin for the Vite dev server
CLIENT_ORIGIN=http://localhost:5173

# One-time tokens required to register staff accounts (role gates)
DOCTOR_REGISTRATION_TOKEN=gara-doctor-2026
FINANCE_REGISTRATION_TOKEN=gara-finance-2026
PHARMACY_REGISTRATION_TOKEN=gara-pharmacy-2026

# --- Optional online integrations (leave blank to stay fully offline) ---
# If GROQ_API_KEY is set, generate-ai-brief calls Groq; otherwise a local
# templated brief is produced so the app works with no internet.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# If both are set, OTP reset emails are sent via Gmail SMTP; otherwise the OTP
# is returned/logged so you can test password reset offline.
GMAIL_SMTP_USER=
GMAIL_SMTP_PASS=
